{
  "name": "dasvio-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev --webpack",
    "build:next": "node ./node_modules/next/dist/bin/next build --webpack",
    "restore:snapshot": "node tools/restore_snapshot.mjs",
    "build": "npm run build:next && npm run restore:snapshot",
    "start": "node ./node_modules/next/dist/bin/next start",
    "preview": "node tools/preview.mjs",
    "lint": "eslint",
    "verify": "python3 tools/verify.py",
    "verify:assets": "python3 tools/verify_assets.py"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.3.0",
    "typescript": "^5"
  }
}
